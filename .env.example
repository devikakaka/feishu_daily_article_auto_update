# ==============================================================================
# Environment Variables for Article Scraper Pipeline
# Copy to .env and fill in your values (do NOT commit .env)
# ==============================================================================

# DashScope (Qwen) API Key
# Get from: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Feishu App Credentials
# Get from: https://open.feishu.cn/app (see docs/FEISHU_SETUP.md)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx